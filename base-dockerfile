# ベースイメージ（ecsforgate-base）のDockerfile
# 目的：四半期ごとに更新される固定バージョンのイメージを提供
# タグ：base-2025-Q2-frozen

FROM ubuntu:22.04

# 必要なパッケージのインストール
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    gnupg2 \
    lsb-release \
    tzdata \
    locales \
    ca-certificates \
    fontconfig \
    unzip \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

# タイムゾーンを日本に設定
RUN ln -fs /usr/share/zoneinfo/Asia/Tokyo /etc/localtime \
    && echo "Asia/Tokyo" > /etc/timezone \
    && dpkg-reconfigure -f noninteractive tzdata

# ロケールを日本語に設定
RUN locale-gen ja_JP.UTF-8
ENV LANG=ja_JP.UTF-8
ENV LANGUAGE=ja_JP:ja
ENV LC_ALL=ja_JP.UTF-8

# Amazon Corretto 11のインストール
RUN curl -L -o /tmp/amazon-corretto-11.tar.gz https://corretto.aws/downloads/latest/amazon-corretto-11-x64-linux-jdk.tar.gz \
    && mkdir -p /usr/lib/jvm \
    && tar -xzf /tmp/amazon-corretto-11.tar.gz -C /usr/lib/jvm \
    && rm /tmp/amazon-corretto-11.tar.gz \
    && mv /usr/lib/jvm/amazon-corretto-* /usr/lib/jvm/amazon-corretto-11

# 環境変数の設定
ENV JAVA_HOME=/usr/lib/jvm/amazon-corretto-11
ENV PATH=$JAVA_HOME/bin:$PATH

# 必要なツールのインストール
RUN apt-get update && apt-get install -y \
    git \
    jq \
    vim \
    less \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

# セキュリティアップデートの適用（四半期ごとの更新戦略に基づく）
RUN apt-get update && apt-get upgrade -y \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Spring Boot アプリケーション用のディレクトリ作成
RUN mkdir -p /app
WORKDIR /app

# メタデータの追加
LABEL maintainer="ECSForgate Team" \
      version="2025-Q2" \
      description="ECSForgate API base image with Ubuntu 22.04 and Amazon Corretto 11" \
      base.image.version="Ubuntu 22.04" \
      java.version="Amazon Corretto 11" \
      build.date="2025-04-27"

# ヘルスチェック用のコマンド
HEALTHCHECK --interval=30s --timeout=3s \
  CMD curl -f http://localhost:8080/api/health || exit 1

# デフォルトのコマンド
CMD ["java", "-version"]
